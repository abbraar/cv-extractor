OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.2

# --- Streamlit Community Cloud ---
# Do not upload .env. In the app on share.streamlit.io: Settings → Secrets, paste TOML like:
# OPENAI_API_KEY = "sk-..."
# OPENAI_MODEL = "gpt-5.2"
# (Same variable names as above; optional keys from this file work the same.)

# Optional: vision model for scanned PDFs (defaults to OPENAI_MODEL).
# OPENAI_VISION_MODEL=gpt-5.2
# Optional: cap scanned pages (default: all pages). Set a positive number to limit cost.
# OPENAI_VISION_MAX_PAGES=20
# OPENAI_VISION_DPI=200

# Windows: Tesseract for local OCR fallback (optional).
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
